# ------------------------------------------------------------------------------
# Miqraa Frontend — Environment Configuration
# ------------------------------------------------------------------------------
# Copy this file to `.env.local` (Vite auto-loads it, git-ignored by default).
# All frontend env vars MUST start with `VITE_` to be exposed to the client.
# ------------------------------------------------------------------------------


# --- Backend API base -------------------------------------------------------
# Optional. Leave empty/unset to use same-origin `/api` (recommended for prod
# behind a reverse proxy).
#
# Local development without a proxy — point straight at the Rust backend:
#     VITE_API_BASE_URL=http://127.0.0.1:3000/api
#
# Production: leave unset, Nginx rewrites /api -> backend.
# VITE_API_BASE_URL=http://127.0.0.1:3000/api
