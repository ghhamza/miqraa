# ------------------------------------------------------------------------------
# Miqraa Backend — Environment Configuration
# ------------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values marked `# REQUIRED`.
# Everything else has a sensible default and can be left commented out.
# ------------------------------------------------------------------------------


# --- Database ---------------------------------------------------------------
# REQUIRED — PostgreSQL 16 connection string.
# Local macOS example (no password, default socket):
#     postgres://$USER@localhost:5432/miqraa
DATABASE_URL=postgres://postgres:postgres@localhost:5432/miqraa


# --- Auth -------------------------------------------------------------------
# REQUIRED — Secret used to sign JWT access tokens.
# Generate with: `openssl rand -hex 64`
# NEVER commit a real secret. NEVER reuse across environments.
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars


# --- HTTP server ------------------------------------------------------------
# Optional. Defaults shown. Set HOST=127.0.0.1 to block LAN in development.
HOST=0.0.0.0
PORT=3000


# --- Recordings storage -----------------------------------------------------
# Optional. Local filesystem path (created at boot if missing).
# Production: point to a persistent volume or swap to S3/MinIO later.
RECORDINGS_PATH=./data/recordings


# --- WebRTC / Media ---------------------------------------------------------
# Optional. Defaults to Google's public STUN server.
STUN_SERVER=stun:stun.l.google.com:19302

# Which SFU backend to use: `webrtc_rs` (default) or `mediasoup`.
APP_MEDIA_BACKEND=webrtc_rs

# mediasoup-only: announced IP for ICE transports.
# Local dev: 127.0.0.1. Production: the server's public IPv4.
APP_MEDIASOUP_ANNOUNCED_IP=127.0.0.1
APP_MEDIASOUP_RTC_MIN_PORT=40000
APP_MEDIASOUP_RTC_MAX_PORT=40100


# --- Quran Foundation API ---------------------------------------------------
# REQUIRED for QF integration (login, streak sync, audio playback).
# Register at https://quran.foundation -> Developers to get credentials.

# Use "prelive" for sandbox, "production" for live.
QF_ENV=prelive

QF_CLIENT_ID=your-qf-client-id-here
QF_CLIENT_SECRET=your-qf-client-secret-here

# REQUIRED — Must exactly match a redirect URI registered on the QF app.
# Local dev:        http://localhost:5173/auth/qf/callback
# Production:       https://app.miqraa.org/auth/qf/callback
QF_REDIRECT_URI=http://localhost:5173/auth/qf/callback

# Optional. Default scopes cover login + streak + activity sync + reading session.
QF_SCOPES=openid offline_access reading_session streak activity_day user

# Optional. CDN base for audio URLs returned as relative paths.
QF_AUDIO_CDN_BASE_URL=https://audio.qurancdn.com


# --- Logging ----------------------------------------------------------------
# Optional. `tracing_subscriber` env filter. Overrides default.
# Examples:
#     RUST_LOG=info
#     RUST_LOG=miqraa_backend=debug,sqlx=warn
# RUST_LOG=info
