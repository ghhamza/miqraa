# 0.0.0.0 = listen on all interfaces (needed for phones / other PCs on the LAN to reach this machine).
# Use HOST=127.0.0.1 only if you want localhost-only.
HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgres://localhost:5432/miqraa
JWT_SECRET=change-me-in-production-bismillah
RECORDINGS_PATH=./data/recordings
STUN_SERVER=stun:stun.l.google.com:19302
# Media backend selection. Options: webrtc_rs (default) or mediasoup.
# webrtc_rs is the current legacy SFU; mediasoup is the new SFU (in progress).
APP_MEDIA_BACKEND=webrtc_rs
# mediasoup settings (only used when APP_MEDIA_BACKEND=mediasoup)
APP_MEDIASOUP_ANNOUNCED_IP=127.0.0.1
APP_MEDIASOUP_RTC_MIN_PORT=40000
APP_MEDIASOUP_RTC_MAX_PORT=40100

QF_ENV=prelive
QF_CLIENT_ID=
QF_CLIENT_SECRET=
QF_REDIRECT_URI=http://localhost:5173/auth/qf/callback
QF_SCOPES=openid offline_access reading_session streak activity_day user
QF_AUDIO_CDN_BASE_URL=https://audio.qurancdn.com
RUST_LOG=miqraa_backend=debug,tower_http=debug
